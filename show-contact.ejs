<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact App</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background: #f4f4f4;
            padding: 20px;
        }
        .contact-card {
            background: #fff;
            padding: 20px;
            max-width: 400px;
            margin: auto;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }
        h2 {
            margin-bottom: 15px;
            color: #333;
        }
        .detail {
            margin: 8px 0;
        }
        .label {
            font-weight: bold;
            color: #555;
        }
        .buttons {
            margin-top: 20px;
        }
        .buttons button {
            padding: 8px 14px;
            margin-right: 8px;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            color: #fff;
        }
        .edit { background: #4CAF50; }
        .delete { background: #f44336; }
        .cancel { background: #777; }
        .buttons button:hover {
            opacity: 0.9;
        }
    </style>
</head>
<body>

    <div class="contact-card">
        <h2>Contact Details</h2>
        <div class="detail"><span class="label">First Name:</span> Alfred</div>
        <div class="detail"><span class="label">Last Name:</span> Kuhlman</div>
        <div class="detail"><span class="label">Email:</span> alfred@test.com</div>
        <div class="detail"><span class="label">Phone:</span> +6286767565656</div>
        <div class="detail"><span class="label">Address:</span> Lorem ipsum dolor</div>

        <div class="buttons">
            <button class="edit">Edit</button>
            <button class="delete">Delete</button>
            <button class="cancel">Cancel</button>
        </div>
    </div>

</body>
</html>
